{
  "name": "mission-control",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names api,ui --prefix-colors cyan,magenta \"tsx server/index.ts\" \"vite --port 5174\"",
    "dev:ui": "vite --port 5174",
    "dev:api": "tsx server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview --port 5174"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.446.0",
    "express": "^4.21.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
